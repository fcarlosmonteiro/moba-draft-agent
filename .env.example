OPENROUTER_API_KEY=
# Slug no OpenRouter; confira em https://openrouter.ai/models
OPENROUTER_MODEL=google/gemini-2.5-flash-lite

# --- Web Django (pip install -e ".[web]"; ver web/README.md)
# DJANGO_SECRET_KEY=
# DJANGO_DEBUG=1
# DRAFT_WEB_USER=admin
# Senha com # no .env precisa de aspas, senão tudo após # vira comentário (fica só "moba"):
# DRAFT_WEB_PASSWORD="moba#draft123"
# Alternativa (Render/senhas especiais): só Base64, sem # no valor
# DRAFT_WEB_PASSWORD_B64=bW9iYSNkcmFmdDEyMw==
# Produção (Render): DJANGO_DEBUG=0, DJANGO_ALLOWED_HOSTS=seu-app.onrender.com
# DJANGO_CSRF_TRUSTED_ORIGINS=https://seu-app.onrender.com
