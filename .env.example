# Copie para .env e preencha (não commite .env).
# Fase 6+: chamadas ao modelo via OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Opcional: se o código rodar fora do clone (ex.: pacote instalado sem dados),
# aponte para a pasta que contém rules/, catalog/, data/
# MOBA_DRAFT_ROOT=/caminho/absoluto/moba-draft-agent
